<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="MediConnect Full Suite" verbose="1" parallel="classes" thread-count="3">

    <listeners>
        <listener class-name="com.cts.mfrp.mediconnect.utils.ExtentReportListener"/>
    </listeners>

    <test name="API Tests">
        <packages>
            <package name="com.cts.mfrp.mediconnect.api.tests"/>
        </packages>
    </test>

    <test name="UI Tests">
        <packages>
            <package name="com.cts.mfrp.mediconnect.ui.tests"/>
        </packages>
    </test>

</suite>
